<?php

declare(strict_types=1);

/**
 * @file
 * Provides an appointment entity type.
 */

use Drupal\appointment\Entity\AppointmentInterface;
use Drupal\Core\Datetime\DrupalDateTime;
use Drupal\Core\Render\Element;
use Drupal\Core\StringTranslation\TranslatableMarkup;

/**
 * Implements hook_views_data_alter().
 */
function appointment_views_data_alter(array &$data): void {

  // Date — proper date picker.
  if (isset($data['appointment']['appointment_date'])) {
    $data['appointment']['appointment_date']['filter']['id'] = 'datetime';
    $data['appointment']['appointment_date']['filter']['field_name'] = 'appointment_date';
  }

  // Status — select list with French labels.
  if (isset($data['appointment']['appointment_status'])) {
    $data['appointment']['appointment_status']['filter']['id'] = 'in_operator';
    $data['appointment']['appointment_status']['filter']['options callback'] = 'appointment_status_filter_options';
  }

  // Agency — select list with agency names.
  if (isset($data['appointment']['appointment_agency'])) {
    $data['appointment']['appointment_agency']['filter']['id'] = 'in_operator';
    $data['appointment']['appointment_agency']['filter']['options callback'] = 'appointment_agency_filter_options';
  }

  // Adviser — select list with adviser names.
  if (isset($data['appointment']['appointment_adviser'])) {
    $data['appointment']['appointment_adviser']['filter']['id'] = 'in_operator';
    $data['appointment']['appointment_adviser']['filter']['options callback'] = 'appointment_adviser_filter_options';
  }

  // Type — select list with type names.
  if (isset($data['appointment']['appointment_type'])) {
    $data['appointment']['appointment_type']['filter']['id'] = 'in_operator';
    $data['appointment']['appointment_type']['filter']['options callback'] = 'appointment_type_filter_options';
  }
}

/**
 * Options callback for appointment_status filter.
 */
function appointment_status_filter_options(): array {
  return [
    'pending'   => new TranslatableMarkup('En attente'),
    'confirmed' => new TranslatableMarkup('Confirmé'),
    'cancelled' => new TranslatableMarkup('Annulé'),
  ];
}

/**
 * Options callback for appointment_agency filter.
 */
function appointment_agency_filter_options(): array {
  $options = [];
  $agencies = \Drupal::entityTypeManager()
    ->getStorage('agency')
    ->loadMultiple();
  foreach ($agencies as $agency) {
    $options[$agency->id()] = $agency->label();
  }
  return $options;
}

/**
 * Options callback for appointment_adviser filter.
 */
function appointment_adviser_filter_options(): array {
  $options = [];
  $ids = \Drupal::entityTypeManager()
    ->getStorage('user')
    ->getQuery()
    ->accessCheck(FALSE)
    ->condition('roles', 'adviser')
    ->condition('status', 1)
    ->sort('name')
    ->execute();
  foreach (\Drupal::entityTypeManager()->getStorage('user')->loadMultiple($ids) as $user) {
    /** @var \Drupal\user\UserInterface $user */
    $options[$user->id()] = $user->getDisplayName();
  }
  return $options;
}

/**
 * Options callback for appointment_type filter.
 */
function appointment_type_filter_options(): array {
  $options = [];
  $terms = \Drupal::entityTypeManager()
    ->getStorage('taxonomy_term')
    ->loadByProperties(['vid' => 'appointment_type']);
  foreach ($terms as $term) {
    $options[$term->id()] = $term->label();
  }
  return $options;
}

/**
 * Implements hook_theme().
 */
function appointment_theme(): array {
  return [
    'agency' => ['render element' => 'elements'],
    'appointment' => ['render element' => 'elements'],
  ];
}

/**
 * Prepares variables for agency templates.
 *
 * Default template: agency.html.twig.
 *
 * @param array $variables
 *   An associative array containing:
 *   - elements: An associative array containing the agency information and any
 *     fields attached to the entity.
 *   - attributes: HTML attributes for the containing element.
 */
function template_preprocess_agency(array &$variables): void {
  $variables['view_mode'] = $variables['elements']['#view_mode'];
  foreach (Element::children($variables['elements']) as $key) {
    $variables['content'][$key] = $variables['elements'][$key];
  }
}

/**
 * Prepares variables for appointment templates.
 *
 * Default template: appointment.html.twig.
 *
 * @param array $variables
 *   An associative array containing:
 *   - elements: An associative array containing the appointment information and any
 *     fields attached to the entity.
 *   - attributes: HTML attributes for the containing element.
 */
function template_preprocess_appointment(array &$variables): void {
  $variables['view_mode'] = $variables['elements']['#view_mode'];
  foreach (Element::children($variables['elements']) as $key) {
    $variables['content'][$key] = $variables['elements'][$key];
  }
}

/**
 * Implements hook_ENTITY_TYPE_presave() for appointment entities.
 */
function appointment_appointment_presave(AppointmentInterface $appointment) {
  if ($appointment->isNew() && empty($appointment->get('reference')->value)) {
    // RDV-2025-17032614-A3F2 (year-timestamp-random)
    $year = date('Y');
    $timestamp = date('dmHis'); // 17032614 = 17 March 26:14
    $random = strtoupper(substr(md5(uniqid((string) mt_rand(), true)), 0, 4));
    $reference = "RDV-{$year}-{$timestamp}-{$random}";
    
    $appointment->set('reference', $reference);
  }
}

/**
 * Implements hook_mail().
 */
function appointment_mail($key, &$message, $params): void {
  $appointment = $params['appointment'] ?? NULL;
  if (!$appointment instanceof AppointmentInterface) {
    return;
  }

  $translator = \Drupal::translation();

  $reference = (string) ($params['reference'] ?? $appointment->get('reference')->value ?? '');
  $date_label = (string) ($params['date_label'] ?? appointment_format_date_label($appointment));

  $agency = $appointment->get('appointment_agency')->entity;
  $adviser = $appointment->get('appointment_adviser')->entity;
  $type = $appointment->get('appointment_type')->entity;

  $agency_label = $agency ? $agency->label() : '-';
  $adviser_label = $adviser ? $adviser->label() : '-';
  $type_label = $type ? $type->label() : '-';

  switch ($key) {
    case 'created':
      $message['subject'] = $translator->translate('Your appointment @reference has been created', ['@reference' => $reference]);
      $message['body'][] = $translator->translate('Your appointment has been created successfully. Keep your reference to modify or cancel it later.');
      break;

    case 'modified':
      $message['subject'] = $translator->translate('Your appointment @reference has been modified', ['@reference' => $reference]);
      $message['body'][] = $translator->translate('Your appointment has been updated successfully.');
      break;

    case 'cancelled':
      $message['subject'] = $translator->translate('Your appointment @reference has been cancelled', ['@reference' => $reference]);
      $message['body'][] = $translator->translate('Your appointment has been cancelled successfully.');
      break;

    default:
      return;
  }

  $message['body'][] = '';
  $message['body'][] = $translator->translate('Reference: @reference', ['@reference' => $reference]);
  $message['body'][] = $translator->translate('Date: @date', ['@date' => $date_label]);
  $message['body'][] = $translator->translate('Agency: @agency', ['@agency' => $agency_label]);
  $message['body'][] = $translator->translate('Appointment type: @type', ['@type' => $type_label]);
  $message['body'][] = $translator->translate('Adviser: @adviser', ['@adviser' => $adviser_label]);
}

/**
 * Formats appointment date for email content.
 */
function appointment_format_date_label(AppointmentInterface $appointment): string {
  $value = (string) ($appointment->get('appointment_date')->value ?? '');
  if ($value === '') {
    return '-';
  }

  $date = new DrupalDateTime($value);
  if ($date->hasErrors()) {
    return $value;
  }

  return $date->format('d/m/Y H:i');
}

